{
  "name": "@ph0ryn/micro",
  "version": "0.3.0",
  "description": "Window-relative macOS automation helpers for TypeScript",
  "repository": {
    "type": "git",
    "url": "https://github.com/ph0ryn/micro.git"
  },
  "license": "MIT",
  "author": "ph0ryn",
  "type": "module",
  "exports": "./src/index.ts",
  "module": "src/index.ts",
  "files": [
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "format": "pnpm run lint --fix . ; oxfmt . ; eslint --fix .",
    "lint": "oxlint --type-aware --type-check",
    "prepack": "clean-pkg-json -r devDependencies",
    "precommit": "pnpm run format",
    "test": "bun test src/window-frame.test.ts src/util.test.ts src/requirements.test.ts && bun test src/opencv.test.ts && bun test src/screen.test.ts src/image.test.ts src/image-finder.test.ts && bun test src/window.test.ts"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "pnpm run precommit"
    ],
    "*.{js,mjs}": [
      "pnpm run format"
    ],
    "*.{json,jsonc}": [
      "pnpm oxfmt ."
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "dependencies": {
    "node-screenshots": "catalog:",
    "opencv-js-wasm": "catalog:",
    "pngjs": "catalog:"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "catalog:",
    "@types/bun": "catalog:",
    "@types/pngjs": "catalog:",
    "@typescript/native-preview": "catalog:",
    "clean-pkg-json": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "sort-package-json": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "bun": ">=1.2.0"
  },
  "os": [
    "darwin"
  ],
  "publishConfig": {
    "access": "public"
  }
}
